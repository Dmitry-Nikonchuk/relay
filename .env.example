# OpenRouter (https://openrouter.ai/)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-thinking:free
OPENROUTER_SUMMARY_MODEL=

# Max HTTP retries per request on 429/502/503 (default 8).
OPENROUTER_MAX_RETRIES=

# App URL (e.g. for OpenRouter referrer)
APP_URL=http://localhost:3000

# Auth.js (https://authjs.dev) — Google OAuth + database sessions (HttpOnly cookies)
# Generate secret: openssl rand -base64 32
AUTH_SECRET=
# Must match the URL users use to open the app (OAuth redirect/callback)
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
